# Disable build of examples
# The build of examples fails to find libgensiomdns.so.6
# so simply remove the examples subdir from Makefiles
# 
# Additionally remove the tests and tools subdirs
# 
--- Makefile.am.orig	2025-11-16 22:38:44.000000000 +0000
+++ Makefile.am	2026-01-30 19:24:00.543967098 +0000
@@ -1,13 +1,12 @@
 
 ACLOCAL_AMFLAGS = -I m4
 
-SUBDIRS = lib $(SWIG_DIR) $(CPLUSPLUS_DIR) include $(GLIB_DIR) $(TCL_DIR) \
-	tests tools examples
+SUBDIRS = lib $(SWIG_DIR) $(CPLUSPLUS_DIR) include $(GLIB_DIR) $(TCL_DIR)
 if INSTALL_DOC
 SUBDIRS += man
 endif
 
-DIST_SUBDIRS = lib swig c++ include glib tcl tests tools examples man
+DIST_SUBDIRS = lib swig c++ include glib tcl
 
 EXTRA_DIST = README.rst reconf ISSUES TODO
 
--- c++/Makefile.am.orig	2025-11-16 22:38:44.000000000 +0000
+++ c++/Makefile.am	2026-01-30 19:22:53.292043313 +0000
@@ -1,4 +1,4 @@
 
