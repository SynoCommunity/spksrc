+++ libavcodec/avcodec.h
@@ -2041,6 +2041,13 @@ typedef struct AVHWAccel {
 #define AV_HWACCEL_FLAG_UNSAFE_OUTPUT (1 << 3)
 
 /**
+ * Some hardware decoders (like VideoToolbox) supports decode session priority
