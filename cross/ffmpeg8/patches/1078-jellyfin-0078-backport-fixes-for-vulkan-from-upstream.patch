+            if (ret != VK_SUCCESS) {
+                av_log(hwctx, AV_LOG_WARNING,
+                       "Failed to get sync fd from DRM map export semaphore: %s\n",
+                       ff_vk_ret2str(ret));
+                sync_fd = -1;
+            }
+        } else {
+            ff_vk_exec_discard_deps(&p->vkctx, exec);
+        }
+    }
+
+    return sync_fd;
+}
