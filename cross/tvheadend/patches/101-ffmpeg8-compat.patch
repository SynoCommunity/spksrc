+    } else if (stream_type == AVMEDIA_TYPE_AUDIO) {
+        // for Audio:
+        // Basic audio properties
+        par->format      = self->iavctx->sample_fmt;
+        par->sample_rate = self->iavctx->sample_rate;
+        par->time_base   = (AVRational){1, self->iavctx->sample_rate};
