+            ,self->iavctx->framerate.num, self->iavctx->framerate.den
+            ,sample_aspect_ratio.num, sample_aspect_ratio.den
+#if LIBAVCODEC_VERSION_MAJOR > 60
+            ,av_color_range_name(self->iavctx->color_range)
