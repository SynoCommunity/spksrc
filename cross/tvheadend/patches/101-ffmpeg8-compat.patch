+        // Copy channel layout (Crucial for FFmpeg 7/8)
+        ret = av_channel_layout_copy(&par->ch_layout, &self->iavctx->ch_layout);
+        if (ret < 0) {
+            tvh_context_log(self, LOG_ERR, "filters: failed to set av_channel_layout with error %d", ret);
+            goto finish;
+        }
