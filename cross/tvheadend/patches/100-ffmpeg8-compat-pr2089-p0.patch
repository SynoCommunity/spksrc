From 7122770a4540e5531074f08831d48e9535c85436 Mon Sep 17 00:00:00 2001
From: Ukn Unknown <4031821+uknunknown@users.noreply.github.com>
Date: Sun, 22 Mar 2026 20:46:14 -0700
Subject: [PATCH] update filter to format required by ffmpeg8

- update the filter initialization from avfilter_graph_create_filter() to avfilter_graph_alloc_filter() +  avfilter_init_str(()
- transition audio filter to aformat for audio conversions.
- patched ffmpeg to allow attach of hw_device_ctx to upload filter
- use codec_type to separate audio from video processing
---
 src/transcoding/codec.h                     |   9 +
 src/transcoding/codec/codecs/aac.c          |   1 +
 src/transcoding/codec/codecs/libs/libx26x.c |  14 +-
 src/transcoding/codec/codecs/libs/vaapi.c   |  90 ++---
 src/transcoding/codec/profile_class.c       |  10 +
 src/transcoding/transcode/audio.c           | 105 +++++-
 src/transcoding/transcode/context.c         | 339 ++++++++++++++++++
 src/transcoding/transcode/graphparser.c     | 364 ++++++++++++++++++++
 src/transcoding/transcode/internals.h       |  32 ++
 src/transcoding/transcode/video.c           |  24 +-

diff --git src/transcoding/codec.h src/transcoding/codec.h
index a16e2a3118..0be1909ed0 100644
--- src/transcoding/codec.h
+++ src/transcoding/codec.h
@@ -93,6 +93,15 @@ struct tvh_codec_profile {
     double qscale;
     int profile;
     char *device; // for hardware acceleration
+    /**
+     * Support for tvh_context_open_filters2()
+     * @note
+     * int: 
+     * VALUE - support
+     * - 0 - no support (use tvh_context_open_filters())
+     * - 1 - has support for tvh_context_open_filters2()
+     */
+    int has_support_for_filter2;
     LIST_ENTRY(tvh_codec_profile) link;
 };
 
diff --git src/transcoding/codec/codecs/aac.c src/transcoding/codec/codecs/aac.c
index 07ef1d6cd5..42eb9301dc 100644
--- src/transcoding/codec/codecs/aac.c
+++ src/transcoding/codec/codecs/aac.c
@@ -75,6 +75,7 @@ tvh_codec_profile_aac_open(tvh_codec_profile_aac_t *self, AVDictionary **opts)
         AV_DICT_SET_GLOBAL_QUALITY(LST_AAC, opts, self->qscale, 1);
     }
     AV_DICT_SET(LST_AAC, opts, "aac_coder", self->coder, 0);
+    ((TVHCodecProfile *)self)->has_support_for_filter2 = 1;
     return 0;
 }
 
diff --git src/transcoding/codec/codecs/libs/libx26x.c src/transcoding/codec/codecs/libs/libx26x.c
index 3457a32f29..d99926c98c 100644
--- src/transcoding/codec/codecs/libs/libx26x.c
+++ src/transcoding/codec/codecs/libs/libx26x.c
@@ -142,16 +142,17 @@ tvh_codec_profile_libx264_open(tvh_codec_profile_libx26x_t *self,
                                AVDictionary **opts)
 {
     // bit_rate or crf
-    if (self->bit_rate) {
-        AV_DICT_SET_BIT_RATE(LST_LIBX26X, opts, self->bit_rate);
+    if (((TVHCodecProfile *)self)->bit_rate) {
+        AV_DICT_SET_BIT_RATE(LST_LIBX26X, opts, ((TVHCodecProfile *)self)->bit_rate);
     }
     else {
-        AV_DICT_SET_CRF(LST_LIBX26X, opts, self->crf, 15);
+        AV_DICT_SET_CRF(LST_LIBX26X, opts, ((TVHVideoCodecProfile *)self)->crf, 15);
     }
     // params
     if (self->params && strlen(self->params)) {
         AV_DICT_SET(LST_LIBX26X, opts, "x264-params", self->params, 0);
     }
+    ((TVHCodecProfile *)self)->has_support_for_filter2 = 1;
     return 0;
 }
 
@@ -241,16 +242,17 @@ tvh_codec_profile_libx265_open(tvh_codec_profile_libx26x_t *self,
