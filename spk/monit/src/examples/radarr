# Example monit configuration for Radarr
# Copy to /var/packages/monit/var/monit.d/ and adjust as needed

check process Radarr with pidfile /var/packages/radarr/var/radarr.pid
    start program = "/var/packages/radarr/scripts/start-stop-status start"
    stop program  = "/var/packages/radarr/scripts/start-stop-status stop"
    if failed host localhost port 8310 for 2 cycles then restart
    if 3 restarts within 5 cycles then timeout
